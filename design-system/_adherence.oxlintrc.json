{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "ui_kits/heros-ledger/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='AttributeMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:attr|value|max|bonus|next|key|ref|className|style|children)$/]",
        "message": "<AttributeMeter> doesn't accept that prop. Declared props: attr, value, max, bonus, next."
      },
      {
        "selector": "JSXOpeningElement[name.name='AttributeMeter'] > JSXAttribute[name.name='attr'] > Literal[value!=/^(?:STR|INT|VIT|DIS|FOC)$/]",
        "message": "<AttributeMeter> attr must be one of 'STR' | 'INT' | 'VIT' | 'DIS' | 'FOC'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|icon|fullWidth|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, icon, fullWidth, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|complete|mini|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'complete' | 'mini' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:accent|tone|active|faded|as|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: accent, tone, active, faded, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:card|panel|well)$/]",
        "message": "<Card> tone must be one of 'card' | 'panel' | 'well'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|children|key|ref|className|style|children)$/]",
        "message": "<Pill> doesn't accept that prop. Declared props: tone, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|gold|green|violet|danger)$/]",
        "message": "<Pill> tone must be one of 'neutral' | 'gold' | 'green' | 'violet' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|kind|color|height|label|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, max, kind, color, height, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:xp|hp|attr|timer)$/]",
        "message": "<ProgressBar> kind must be one of 'xp' | 'hp' | 'attr' | 'timer'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RarityTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:rarity|key|ref|className|style|children)$/]",
        "message": "<RarityTag> doesn't accept that prop. Declared props: rarity."
      },
      {
        "selector": "JSXOpeningElement[name.name='RarityTag'] > JSXAttribute[name.name='rarity'] > Literal[value!=/^(?:common|rare|epic)$/]",
        "message": "<RarityTag> rarity must be one of 'common' | 'rare' | 'epic'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|icon|show|children|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: color, icon, show, children."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
